NODE_ENV=development
PORT=3000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=jobmajunga
DB_PASSWORD=jobmajunga
DB_NAME=jobmajunga2

JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# SMTP (mot de passe oublié)
# Si non configuré, le backend n'envoie pas de mail et affiche le lien dans les logs.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="JobMajunga2 <no-reply@jobmajunga.local>"

# Lien de reset (frontend). Le backend ajoutera ?token=...&email=...
PASSWORD_RESET_URL=http://localhost:5173/reset-password

